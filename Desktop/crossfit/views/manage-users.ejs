<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>Manage Users</title>
   
<!-- Include jQuery first -->
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  
  <!-- Then include Bootstrap -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  <!-- Finally, include Bootstrap Datepicker -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-datepicker@1.9.0/dist/css/bootstrap-datepicker.min.css">
  <!-- Make sure to include the Popper.js library -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/2.11.6/umd/popper.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap-datepicker@1.9.0/dist/js/bootstrap-datepicker.min.js"></script>
 

  <link rel="stylesheet" href="/styles/content.css">

</head>
<%- include("partials/header.ejs") %>

<div class="mb-3"></div>

  <h5 class="fs-4">Manage Users</h5>

  <div class="mb-3"></div>

  

  <table class="table">
    <thead>
      <tr>
        <th scope="col">#</th>
        <th scope="col">Name</th>
        <th scope="col">Age</th>
        <th scope="col">Weight(kg)</th>
       <th scope="col"></th>
       <th scope="col"></th>
         
      </tr>
    </thead>
    <tbody>
      <% users.forEach((user, index) => { %>
        <tr>
          <th scope="row"><%= index + 1 %></th>
          <td><%= user.name %></td>
          <td><%= user.age %></td>
          <td><%= user.weight %></td>

         <td>
          <!-- Add an Update button for each user -->
          <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#updateModal<%= user.id %>">Update</button>
        </td>
        <td>
          <!-- Add button for deleting user -->
          <button class="btn btn-sm btn-danger" onclick="deleteUser(<%= user.id %>)">Delete</button>
        </td>
       
        </tr>

              <!-- Modal for each user -->
              
      <div class="modal fade" id="updateModal<%= user.id %>" tabindex="-1" aria-labelledby="updateModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="updateModalLabel">Update User</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <form method="post" action="/update-user/<%= user.id %>">
          <div class="mb-3">
            <label for="updateName" class="form-label">Name:</label>
            <input type="text" id="updateName" name="updateName" class="form-control" value="<%= user.name %>">
          </div>
          <div class="mb-3">
            <label for="updateAge" class="form-label">Age:</label>
            <input type="text" id="updateAge" name="updateAge" class="form-control" value="<%= user.age %>">
          </div>
          <div class="mb-3">
            <label for="updateWeight" class="form-label">Weight (kg):</label>
            <input type="text" id="updateWeight" name="updateWeight" class="form-control" value="<%= user.weight %>">
          </div>

          <button type="submit" class="btn btn-primary">Submit</button>
        </form>
            </div>
          </div>
        </div>
      </div>

      <% }); %>
    </tbody>
  </table>

    <div class="mb-5"></div>
  <h5 class="fs-4">Add Users</h5> 

 <form>
  <div class="row">
    <!-- Column 1 -->
    <div class="col-md-3">
      <div class="mb-3">
        <label for="addName" class="form-label">Name:</label>
        <input type="text" id="addName" name="addName" class="form-control">
      </div>
    </div>

    <!-- Column 2 -->
    <div class="col-md-3">
      <div class="mb-3">
        <label for="addAge" class="form-label">Age:</label>
        <input type="number" id="addAge" name="addAge" class="form-control">
      </div>
    </div>

    <!-- Column 3 -->
    <div class="col-md-3">
      <div class="mb-3">
        <label for="addWeight" class="form-label">Weight:</label>
        <input type="number" id="addWeight" name="addWeight" class="form-control">
      </div>
    </div>

      <!-- Column 4 -->
     <div class="col-md-3">
      <div class="mb-3">
         <button type="submit" class="btn btn-primary">Submit</button>
      </div>
    </div>

  </div>

 
</form>


<div class="modal" tabindex="-1" id="successModal" hidden>
  <div class="modal-dialog  modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-body">
        <p> Data updated successfully for <span id="modalUserId"></span> ! </p>
      </div>
      <div class="modal-footer">

        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>

      </div>

</div>
<%- include("partials/footer.ejs") %>

<script>
  // Add this inside your document ready function or wherever you have your JavaScript logic
    $('#successModal').on('hidden.bs.modal', function (e) {
  // Redirect to the log page after modal is closed
    window.location.href = '/manage-users';});
</script>
</body>
</html>